{
  "hooks": {
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"additionalContext\": \"Available dev-flow MCP tools (use these instead of ToolSearch): dev_status (~30t), dev_flow (~100t), dev_config (~50t), dev_ledger (~50t), dev_tasks (~30t), dev_coordinate (~40t), dev_handoff (~50t), dev_aggregate (~60t), dev_commit (~30t), dev_memory (~60t), dev_changes (~50t), dev_defaults (~20t), dev_version (~30t), dev_commits (~100t), dev_inbox (~50t), dev_spec (~50t), dev_branch (~30t), dev_check (~10t), dev_fix (~20t), dev_next (~15t), dev_ready (~20t). Read tool for files. Grep/Glob for search. Bash for git/shell. Never call claude CLI from Bash.\"}'",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/url-reader.sh",
            "timeout": 3,
            "statusMessage": "Detecting URLs..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-commit-check.sh",
            "timeout": 5,
            "statusMessage": "Checking knowledge pitfalls..."
          }
        ]
      },
      {
        "matcher": "Bash(*git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/commit-guard.sh",
            "timeout": 3,
            "statusMessage": "Validating commit flow..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start-continuity.sh",
            "timeout": 10,
            "statusMessage": "Loading project context...",
            "once": true
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/memory-sync.sh",
            "timeout": 5,
            "statusMessage": "Syncing memory...",
            "once": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-compact.sh",
            "timeout": 10,
            "statusMessage": "Backing up transcript..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-summary.sh",
            "timeout": 15,
            "statusMessage": "Saving session summary..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-end.sh",
            "timeout": 10,
            "statusMessage": "Saving session state..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/task-checkpoint.sh",
            "timeout": 5000,
            "statusMessage": "Checkpointing task..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/batch-checkpoint.sh",
            "timeout": 5000,
            "statusMessage": "Batch checkpoint check..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/quality-gate-check.sh",
            "timeout": 5000,
            "statusMessage": "Quality gate check..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/scope-drift-check.sh",
            "timeout": 5,
            "async": true,
            "statusMessage": "Checking scope drift..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate-versions.sh",
            "timeout": 5,
            "statusMessage": "Checking version consistency..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/post-edit-format.sh",
            "timeout": 10,
            "async": true,
            "statusMessage": "Auto-formatting..."
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|Bash|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/tool-counter.sh",
            "timeout": 3,
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash(git *)|Bash(gh *)",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/dev-workflow.sh",
            "timeout": 10,
            "statusMessage": "Checking dev workflow..."
          }
        ]
      },
      {
        "matcher": "TeamCreate",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/track-team.sh create",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "TeamDelete",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/track-team.sh delete",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash(git merge*)|Bash(git push*)|Bash(*git merge*)|Bash(*git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/post-merge-notion.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__plugin_dev-flow_dev-flow__dev_commit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/post-impl-extract.sh",
            "timeout": 5,
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/docs-lint.sh",
            "timeout": 3,
            "async": true
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/docs-reminder.sh",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ]
  }
}
